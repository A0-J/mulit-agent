app:
  description: 'Multi-agent customer service demo handling Account, Payment, and Bug reports.'
  icon: 🤖
  icon_background: '#FFEAD5'
  mode: advanced-chat
  name: Customer_Service_Multi_Agent_Demo
  use_icon_as_answer_icon: false

kind: app
version: 0.1.5

workflow:
  conversation_variables:
    - description: 'Stores the interaction history between user and agents'
      id: abefe77b-c4bf-4556-958e-3464f170b64b
      name: history
      selector:
        - conversation
        - history
      value: []
      value_type: array[string]

  features:
    file_upload:
      enabled: false
    opening_statement: 'Hello! How can I help you today? (Account, Payment, or Bug reports)'
    retriever_resource:
      enabled: true

  graph:
    nodes:
      # 1. 시작 노드 (Start)
      - data:
          title: Start_Node
          type: start
        id: '1742202974224'

      # 2. 사용자 메시지 템플릿 (User Message Formatting)
      - data:
          template: 'User: {{ arg1 }}'
          title: User_Message_Template
          type: template-transform
          variables:
            - value_selector: [sys, query]
              variable: arg1
        id: '1742350994298'

      # 3. 대화 기록 업데이트 (Update Chat History)
      - data:
          items:
            - input_type: variable
              operation: append
              value: ['1742350994298', output]
              variable_selector: [conversation, history]
              write_mode: over-write
          title: Update_History_Assigner
          type: assigner
        id: '1742350971437'

      # 4. 질문 분류기 (Intent Classifier)
      - data:
          classes:
            - id: '1'
              name: Account_Issues # 계정 관련 문제
            - id: '2'
              name: Payment_Issues # 결제 관련 문제
            - id: '1742366386789'
              name: General_Inquiry # 일반 문의 및 분류 불가
            - id: '1742876076568'
              name: Bug_and_Suggestions # 버그 제보 및 건의
          instruction: |
            Identify the user's intent based on the conversation history.
            <history>
            {{#1742365438889.output#}}
            </history>
          model:
            name: us.anthropic.claude-3-7-sonnet-20250219-v1:0
            provider: langgenius/bedrock/bedrock
          title: Intent_Classifier
          type: question-classifier
        id: '1742364688771'

      # 5. 계정 전담 에이전트 (Account Agent)
      - data:
          agent_parameters:
            instruction: |
              You are a security-focused account assistant.
              Your task is to handle ACCOUNT related issues (Bans, Login, etc.).
              History: {{#conversation.history#}}
            model:
              model: us.anthropic.claude-3-7-sonnet-20250219-v1:0
              provider: langgenius/bedrock/bedrock
          tools:
            - tool_label: Get_User_Ban_Status # 사용자 계정 상태 확인
              tool_name: get_user_ban_status
            - tool_label: Request_Human_Service # 상담원 연결
              tool_name: request_human_service
          title: Account_Agent
          type: agent
        id: '1742202983138'

      # 6. 결제 전담 에이전트 (Payment Agent)
      - data:
          agent_parameters:
            instruction: |
              You are a payment specialist. Handle billing and order inquiries.
              History: {{#conversation.history#}}
            model:
              model: ep-20250326163918-p9rd5
              provider: langgenius/volcengine_maas/volcengine_maas
          tools:
            - tool_label: Get_Order_Status # 주문 결제 상태 조회
              tool_name: get_order_status
            - tool_label: Request_Human_Service
              tool_name: request_human_service
          title: Payment_Agent
          type: agent
        id: '17423656891550'

      # 7. 버그/건의 에이전트 (Bug & Suggestion Agent)
      - data:
          agent_parameters:
            instruction: |
              Handle game bugs and user suggestions.
              History: {{#conversation.history#}}
            model:
              model: gpt-4o
              provider: langgenius/azure_openai/azure_openai
          tools:
            - tool_label: Request_Human_Service
              tool_name: request_human_service
          title: Bug_Suggestion_Agent
          type: agent
        id: '1742876104154'

      # 8. 메인 에이전트 (Main/General Agent)
      - data:
          agent_parameters:
            instruction: |
              Ask the user to clarify if they need help with Account or Payment issues.
              History: {{#conversation.history#}}
            model:
              model: us.anthropic.claude-3-7-sonnet-20250219-v1:0
              provider: langgenius/bedrock/bedrock
          title: Main_Agent
          type: agent
        id: '17423664651770'

      # 9. 응답 취합 및 기록 (Response Aggregation & Final Update)
      - data:
          title: Variable_Aggregator # 에이전트들의 답변을 수집
          type: variable-aggregator
          variables:
            - ['17423656891550', text]
            - ['1742202983138', text]
            - ['17423664651770', text]
            - ['1742876104154', text]
        id: '1742366248145'

      - data:
          template: 'Agent: {{ arg1 }}'
          title: Final_Response_Template
          type: template-transform
          variables:
            - value_selector: ['1742366248145', output]
              variable: arg1
        id: '1742366139536'

      - data:
          items:
            - input_type: variable
              operation: append
              value: ['1742366139536', output]
              variable_selector: [conversation, history]
              write_mode: over-write
          title: Final_History_Update # 상담원 답변을 기록에 추가
          type: assigner
        id: '1742366188205'
